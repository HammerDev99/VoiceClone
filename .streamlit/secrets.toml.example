# Plantilla de secretos para Streamlit Community Cloud.
#
# LOCAL: no necesitas este archivo; la app lee de .env.
# DESPLIEGUE: copia este contenido (con valores reales) en
#   Streamlit Cloud -> App -> Settings -> Secrets
# o, para probar en local con secrets, cópialo a .streamlit/secrets.toml
# (ese archivo real está gitignored; NUNCA lo subas).

ELEVENLABS_API_KEY = "sk_tu_api_key"
ELEVENLABS_MODEL_ID = "eleven_multilingual_v2"
ELEVENLABS_OUTPUT_FORMAT = "mp3_44100_128"

ANTHROPIC_API_KEY = "sk-ant-tu_api_key"
ANTHROPIC_MODEL = "claude-opus-4-8"

VOICE_NAME = "Alexander"
VOICE_ID = "YGZ9Wy0OURezjISirtC4"
VOICE_PRESET = "calido_sereno"

LOG_LEVEL = "INFO"

# Analítica web opcional (Umami). Pega aquí el snippet completo tal cual lo entrega
# tu panel de Umami; la app extrae el src y el data-website-id automáticamente.
# Si lo dejas vacío o no lo incluyes, la analítica simplemente queda desactivada.
ANALYTICS_SCRIPT = '<script defer src="https://analytics.sprintjudicial.com/script.js" data-website-id="747d8b89-4c3d-4b25-9b79-e538bd831bce"></script>'
