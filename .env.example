# =====================================================================
# VoiceClone - Plantilla de variables de entorno
# ---------------------------------------------------------------------
# 1. Copia este archivo a ".env"  ->  cp .env.example .env
# 2. Rellena los valores reales.
# 3. NUNCA subas ".env" al repositorio (ya esta en .gitignore).
# =====================================================================

# --- ElevenLabs (clonado de voz + sintesis TTS) ---
# Obtener en: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=sk_tu_api_key_aqui

# Modelo de sintesis. eleven_multilingual_v2 soporta espanol con alta calidad.
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# Formato de salida del audio generado.
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128

# --- Anthropic (capa conversacional con la personalidad de Alexander) ---
# Obtener en: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-tu_api_key_aqui

# Modelo de Claude para generar las respuestas con la personalidad.
ANTHROPIC_MODEL=claude-opus-4-8

# --- Configuracion de la voz / persona ---
# Nombre con el que se registra la voz clonada en ElevenLabs.
VOICE_NAME=Alexander

# ID de la voz ya clonada (se rellena automaticamente tras ejecutar el
# script de clonado; permite reutilizarla sin volver a clonar).
VOICE_ID=

# Preset de afinado de voz: calido_sereno | natural
VOICE_PRESET=calido_sereno

# --- Rutas (relativas a la raiz del proyecto; normalmente no se cambian) ---
AUDIO_INPUT_DIR=audios
AUDIO_OUTPUT_DIR=output

# --- Logging ---
# Niveles: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
